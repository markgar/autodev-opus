{
  "name": "autodev",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "build:server": "tsc -p src/server/tsconfig.json",
    "build:client": "vite build",
    "build": "npm run build:server && npm run build:client",
    "dev": "concurrently -n server,client -c blue,green \"NODE_ENV=development tsx watch src/server/index.ts\" \"vite dev --port 5173\"",
    "start": "node dist/server/index.js",
    "test:server": "vitest run --config src/server/vitest.config.ts",
    "test:client": "vitest run --config src/client/vitest.config.ts",
    "test": "npm run test:server && npm run test:client"
  },
  "dependencies": {
    "@azure/cosmos": "^4.9.1",
    "@azure/identity": "^4.13.0",
    "@azure/storage-blob": "^12.31.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "lucide-react": "^0.576.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
