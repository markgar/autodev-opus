{
  "name": "autodev",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "build:server": "tsc -p src/server/tsconfig.json",
    "build:client": "vite build",
    "build": "npm run build:server && npm run build:client",
    "dev": "concurrently -n server,client -c blue,green \"tsx watch src/server/index.ts\" \"vite dev --port 5173\"",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "express": "^5.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
